<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@color/fondo_principal">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_margin="16dp"
        android:src="@drawable/icono"
        android:contentDescription="@string/app_name"
        android:scaleType="centerCrop" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:hint="Usuario"
        app:endIconDrawable="@drawable/ic_person"
        app:endIconTint="@color/fondo_principal"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="50dp"
        app:boxCornerRadiusTopEnd="50dp"
        app:boxCornerRadiusBottomStart="50dp"
        app:boxCornerRadiusBottomEnd="50dp"
        app:boxStrokeColor="@color/boton_principal"
        app:hintTextColor="@color/boton_principal"
        app:boxStrokeWidth="2dp"
        app:boxBackgroundColor="@android:color/white">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editUserName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:paddingEnd="40dp"
            android:inputType="textPersonName" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:hint="Contraseña"
        app:startIconTint="@color/boton_principal"
        app:endIconMode="password_toggle"
        app:endIconTint="@color/fondo_principal"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="50dp"
        app:boxCornerRadiusTopEnd="50dp"
        app:boxCornerRadiusBottomStart="50dp"
        app:boxCornerRadiusBottomEnd="50dp"
        app:boxStrokeColor="@color/boton_principal"
        app:boxStrokeWidth="2dp"
        app:hintTextColor="@color/boton_principal"
        app:boxBackgroundColor="@color/texto_principal">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="@color/black"/>
    </com.google.android.material.textfield.TextInputLayout>

    <CheckBox
        android:id="@+id/checkboxAutoLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Recordar Usuario"
        android:textColor="@color/alerta_pixel"/>

    <Button
        android:id="@+id/butonLogin"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:text="LOG IN"
        android:backgroundTint="@color/boton_principal"
        android:textColor="@color/fondo_principal"/>

    <Button
        android:id="@+id/butonRegistrer"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="REGISTRATE"
        android:backgroundTint="@color/boton_principal"
        android:textColor="@color/fondo_principal"/>



</LinearLayout>