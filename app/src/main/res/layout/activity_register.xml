<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_principal">

    <TextView
        android:id="@+id/textViewWelcome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:layout_gravity="center"
        android:textAlignment="center"
        android:layout_margin="16dp"
        android:textSize="40sp"
        android:textStyle="bold"
        android:text="Formulario registro"
        android:textColor="@color/fondo_principal"
        android:background="@color/boton_principal"
        />

    <EditText
        android:id="@+id/editTextUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="18dp"
        android:layout_marginTop="86dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:hint="Introduzca su usuario"
        android:textColorHint="@color/hint"
        android:textColor="@color/texto_principal"
        android:backgroundTint="@color/boton_principal"/>

    <EditText
        android:id="@+id/editTextEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="18dp"
        android:layout_margin="16dp"
        android:hint="Introduzca su email"
        android:textColorHint="@color/hint"
        android:textColor="@color/texto_principal"
        android:backgroundTint="@color/boton_principal"/>

    <EditText
        android:id="@+id/editTextPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="18dp"
        android:layout_margin="16dp"
        android:hint="Introduzca su password"
        android:textColorHint="@color/hint"
        android:textColor="@color/texto_principal"
        android:backgroundTint="@color/boton_principal"
        android:inputType="number"/>


    <Button
        android:id="@+id/btnRegister"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="140dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:padding="18dp"
        android:textSize="22sp"
        android:text="Registro"
        android:backgroundTint="@color/boton_principal"
        android:textColor="@color/fondo_principal"/>

</LinearLayout>